---
import { siteConfig } from '@/config';

const { footer } = siteConfig;
const footerLinks = footer.columns.flatMap((col) => col.links || []);
---

<footer class="bg-gray-50 dark:bg-slate-900 border-t border-gray-100 dark:border-gray-800 mt-20">
  <div class="max-w-6xl mx-auto px-4 py-5">
    <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-3 text-sm text-gray-500 dark:text-gray-400">
      <div class="flex flex-wrap items-center gap-x-2 gap-y-1">
        {footerLinks.map((link, index) => (
          <>
            {index > 0 && <span class="text-gray-300 dark:text-gray-600">|</span>}
            <a
              href={link.url}
              class="hover:text-primary transition-colors"
            >
              {link.label}
            </a>
          </>
        ))}
      </div>

      <div class="flex flex-wrap items-center gap-2 md:justify-end">
        <span>{footer.copyright}</span>
        {footer.icp && (
          <>
            <span class="text-gray-300 dark:text-gray-600">|</span>
            <a
              href="https://beian.miit.gov.cn/"
              target="_blank"
              rel="noopener noreferrer"
              class="hover:text-primary transition-colors"
            >
              {footer.icp}
            </a>
          </>
        )}
      </div>
    </div>
  </div>
</footer>
